{
  "name": "heatmark",
  "version": "1.0.0",
  "description": "HeatMark - Thermal Label Designer & Printer",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@icon-park/vue-next": "^1.4.2",
    "axios": "^1.7.0",
    "element-plus": "^2.8.0",
    "fabric": "^6.5.0",
    "pinia": "^2.2.0",
    "vue": "^3.5.0"
  },
  "build": {
    "appId": "com.heatmark.app",
    "productName": "HeatMark",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!__pycache__", "!*.pyc"]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
